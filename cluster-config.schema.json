{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OpenSearch Sample CDK Configuration",
  "description": "Configuration schema for amazon-opensearch-service-sample-cdk",
  "type": "object",
  "required": ["stage", "clusters"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference (ignored by CDK)"
    },
    "stage": {
      "type": "string",
      "maxLength": 15,
      "description": "Deployment stage name (e.g. dev, staging, prod)"
    },
    "vpcId": {
      "type": "string",
      "pattern": "^vpc-[a-z0-9]+$",
      "description": "Import an existing VPC by ID instead of creating one"
    },
    "vpcAZCount": {
      "type": "integer",
      "minimum": 1,
      "maximum": 3,
      "description": "Number of Availability Zones for the VPC (1-3)"
    },
    "vpcCidr": {
      "type": "string",
      "description": "CIDR block for the VPC (default: 10.212.0.0/16)"
    },
    "tags": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "description": "Custom tags to apply to all resources (key-value pairs)"
    },
    "clusters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/cluster"
      }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "cluster": {
      "type": "object",
      "required": ["clusterId", "clusterType"],
      "properties": {
        "clusterId": {
          "type": "string",
          "maxLength": 15,
          "description": "Unique identifier for this cluster"
        },
        "clusterType": {
          "type": "string",
          "enum": ["OPENSEARCH_MANAGED_SERVICE", "OPENSEARCH_SERVERLESS"],
          "description": "Type of OpenSearch deployment"
        }
      },
      "if": {
        "properties": { "clusterType": { "const": "OPENSEARCH_MANAGED_SERVICE" } }
      },
      "then": { "$ref": "#/definitions/managedCluster" },
      "else": {
        "if": {
          "properties": { "clusterType": { "const": "OPENSEARCH_SERVERLESS" } }
        },
        "then": { "$ref": "#/definitions/serverlessCluster" }
      }
    },
    "managedCluster": {
      "properties": {
        "clusterId": true,
        "clusterType": true,
        "clusterName": {
          "type": "string",
          "description": "Custom name for the cluster (default: cluster-<stage>-<clusterId>)"
        },
        "domainRemovalPolicy": {
          "type": "string",
          "enum": ["DESTROY", "RETAIN", "SNAPSHOT"],
          "description": "What happens to the domain when the stack is deleted"
        },
        "clusterVersion": {
          "type": "string",
          "pattern": "^(OS_|ES_)",
          "description": "Engine version (e.g. OS_2.19, ES_7.10)"
        },
        "clusterSubnetIds": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Specific subnet IDs for the domain (for imported VPCs)"
        },
        "clusterSecurityGroupIds": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Additional security group IDs for the domain"
        },
        "dataNodeType": {
          "type": "string",
          "description": "Instance type for data nodes (e.g. r6g.large.search)"
        },
        "dataNodeCount": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of data nodes"
        },
        "dedicatedManagerNodeType": {
          "type": "string",
          "description": "Instance type for dedicated manager nodes"
        },
        "dedicatedManagerNodeCount": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of dedicated manager nodes"
        },
        "warmNodeType": {
          "type": "string",
          "description": "Instance type for warm nodes"
        },
        "warmNodeCount": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of warm nodes"
        },
        "useUnsignedBasicAuth": {
          "type": "boolean",
          "description": "Enable unsigned basic auth for the domain"
        },
        "fineGrainedManagerUserARN": {
          "type": "string",
          "description": "ARN of the IAM user for fine-grained access control"
        },
        "fineGrainedManagerUserSecretARN": {
          "type": "string",
          "description": "ARN of the Secrets Manager secret for fine-grained access"
        },
        "enableDemoAdmin": {
          "type": "boolean",
          "description": "Create a demo admin user (insecure - for testing only)"
        },
        "enforceHTTPS": {
          "type": "boolean",
          "description": "Require HTTPS for all traffic to the domain"
        },
        "tlsSecurityPolicy": {
          "type": "string",
          "enum": ["TLS_1_0", "TLS_1_2", "TLS_1_2_PFS"],
          "description": "Minimum TLS version"
        },
        "ebsEnabled": {
          "type": "boolean",
          "description": "Enable EBS storage for data nodes"
        },
        "ebsIops": {
          "type": "integer",
          "minimum": 0,
          "description": "IOPS for EBS volumes (GP3/IO1/IO2 only)"
        },
        "ebsThroughput": {
          "type": "integer",
          "minimum": 0,
          "description": "Throughput in MiB/s for EBS volumes (GP3 only)"
        },
        "ebsVolumeSize": {
          "type": "integer",
          "minimum": 10,
          "description": "EBS volume size in GiB"
        },
        "ebsVolumeType": {
          "type": "string",
          "enum": ["GP2", "GP3", "IO1", "IO2", "STANDARD"],
          "description": "EBS volume type"
        },
        "encryptionAtRestEnabled": {
          "type": "boolean",
          "description": "Enable encryption at rest"
        },
        "encryptionAtRestKmsKeyARN": {
          "type": "string",
          "description": "KMS key ARN for encryption at rest"
        },
        "loggingAppLogEnabled": {
          "type": "boolean",
          "description": "Enable application logging"
        },
        "loggingAppLogGroupARN": {
          "type": "string",
          "description": "CloudWatch Log Group ARN for application logs"
        },
        "slowSearchLogEnabled": {
          "type": "boolean",
          "description": "Enable slow search log publishing"
        },
        "slowSearchLogGroupARN": {
          "type": "string",
          "description": "CloudWatch Log Group ARN for slow search logs"
        },
        "auditLogEnabled": {
          "type": "boolean",
          "description": "Enable audit log publishing (requires fine-grained access control)"
        },
        "auditLogGroupARN": {
          "type": "string",
          "description": "CloudWatch Log Group ARN for audit logs"
        },
        "nodeToNodeEncryptionEnabled": {
          "type": "boolean",
          "description": "Enable node-to-node encryption"
        },
        "openAccessPolicyEnabled": {
          "type": "boolean",
          "description": "Enable open access policy (allows all principals)"
        },
        "accessPolicies": {
          "type": "object",
          "description": "IAM access policy document for the domain"
        },
        "coldStorageEnabled": {
          "type": "boolean",
          "description": "Enable UltraWarm cold storage"
        },
        "multiAZWithStandbyEnabled": {
          "type": "boolean",
          "description": "Enable Multi-AZ with Standby"
        },
        "offPeakWindowEnabled": {
          "type": "boolean",
          "description": "Enable off-peak maintenance window"
        },
        "samlEntityId": {
          "type": "string",
          "description": "SAML identity provider entity ID"
        },
        "samlMetadataContent": {
          "type": "string",
          "description": "SAML metadata XML content"
        },
        "samlMasterUserName": {
          "type": "string",
          "description": "SAML master username for OpenSearch Dashboards"
        },
        "samlMasterBackendRole": {
          "type": "string",
          "description": "SAML master backend role"
        },
        "samlRolesKey": {
          "type": "string",
          "description": "SAML assertion element for backend roles"
        },
        "samlSubjectKey": {
          "type": "string",
          "description": "SAML assertion element for user name"
        },
        "samlSessionTimeoutMinutes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1440,
          "description": "SAML session timeout in minutes (default: 60)"
        },
        "cognitoUserPoolId": {
          "type": "string",
          "description": "Cognito User Pool ID for Dashboards authentication"
        },
        "cognitoIdentityPoolId": {
          "type": "string",
          "description": "Cognito Identity Pool ID for Dashboards authentication"
        },
        "cognitoRoleArn": {
          "type": "string",
          "description": "IAM Role ARN for Cognito authentication"
        },
        "customEndpoint": {
          "type": "string",
          "description": "Custom domain endpoint (e.g. search.example.com)"
        },
        "customEndpointCertificateArn": {
          "type": "string",
          "description": "ACM certificate ARN for the custom domain endpoint"
        },
        "autoTuneEnabled": {
          "type": "boolean",
          "description": "Enable Auto-Tune for automatic performance optimization"
        }
      },
      "additionalProperties": false
    },
    "serverlessCluster": {
      "properties": {
        "clusterId": true,
        "clusterType": true,
        "clusterName": {
          "type": "string",
          "description": "Custom name for the cluster (default: cluster-<stage>-<clusterId>)"
        },
        "domainRemovalPolicy": {
          "type": "string",
          "enum": ["DESTROY", "RETAIN", "SNAPSHOT"],
          "description": "What happens to the domain when the stack is deleted"
        },
        "collectionType": {
          "type": "string",
          "enum": ["SEARCH", "TIMESERIES", "VECTORSEARCH"],
          "description": "Serverless collection type (default for all collections in the group)"
        },
        "standbyReplicas": {
          "type": "string",
          "enum": ["ENABLED", "DISABLED"],
          "description": "Serverless standby replicas"
        },
        "vpcEndpointId": {
          "type": "string",
          "description": "VPC endpoint ID - restricts access to this endpoint (disables public access)"
        },
        "collections": {
          "type": "array",
          "minItems": 1,
          "description": "Collection group - multiple collections sharing encryption, network, and data-access policies",
          "items": {
            "type": "object",
            "required": ["collectionName"],
            "properties": {
              "collectionName": {
                "type": "string",
                "description": "Name of the collection"
              },
              "collectionType": {
                "type": "string",
                "enum": ["SEARCH", "TIMESERIES", "VECTORSEARCH"],
                "description": "Collection type (overrides the cluster-level collectionType)"
              }
            },
            "additionalProperties": false
          }
        },
        "dataAccessPrincipals": {
          "type": "array",
          "items": { "type": "string" },
          "description": "IAM principal ARNs for data access policy (default: account root)"
        },
        "sourceIPAddresses": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Source IP addresses (CIDR notation) for network policy restriction"
        }
      },
      "additionalProperties": false
    }
  }
}
