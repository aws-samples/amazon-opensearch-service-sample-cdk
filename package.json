{
  "name": "opensearch-service-domain-cdk",
  "description": "CDK infrastructure for deploying search clusters to AWS",
  "keywords": [
    "aws",
    "cdk",
    "opensearch",
    "elasticsearch",
    "infrastructure"
  ],
  "version": "0.2.7",
  "main": "dist/lib/index.js",
  "types": "dist/lib/index.d.ts",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/lib/index.d.ts",
      "import": "./dist/lib/index.js",
      "require": "./dist/lib/index.js"
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aws-samples/amazon-opensearch-service-sample-cdk.git",
    "directory": "/"
  },
  "bugs": {
    "url": "https://github.com/aws-samples/amazon-opensearch-service-sample-cdk/issues"
  },
  "homepage": "https://github.com/aws-samples/amazon-opensearch-service-sample-cdk#readme",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npx tsc",
    "watch": "npx tsc -w",
    "test": "npm run test:lint && npm run test:jest",
    "test:lint": "npx eslint .",
    "test:jest": "npx jest --coverage",
    "clean": "rm -rf dist",
    "validate": "npx cdk synth --no-staging -q",
    "prepublishOnly": "npm run build",
    "cdk": "npx cdk"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "25.3.3",
    "aws-cdk": "2.1109.0",
    "aws-cdk-lib": "2.241.0",
    "cdk-nag": "^2.37.55",
    "constructs": "^10.5.1",
    "eslint": "^10.0.2",
    "jest": "^30.2.0",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "peerDependencies": {
    "aws-cdk-lib": "^2.150.0",
    "constructs": "^10.4.2"
  },
  "overrides": {
    "semver": "^7.7.1"
  }
}
